menu "Multicast Replayer (P4)"

    choice MCR_ETH_PHY
        prompt "Ethernet PHY model"
        default MCR_ETH_PHY_IP101
        help
            RMII PHY chip wired to the ESP32-P4 EMAC.

        config MCR_ETH_PHY_IP101
            bool "IP101"
        config MCR_ETH_PHY_LAN87XX
            bool "LAN87xx"
        config MCR_ETH_PHY_RTL8201
            bool "RTL8201"
        config MCR_ETH_PHY_DP83848
            bool "DP83848"
        config MCR_ETH_PHY_KSZ80XX
            bool "KSZ80xx"
    endchoice

    config MCR_ETH_PHY_ADDR
        int "PHY address (-1 = autodetect)"
        range -1 31
        default -1

    config MCR_ETH_PHY_RST_GPIO
        int "PHY reset GPIO (-1 = not connected)"
        default -1

    config MCR_SD_PIN_CMD
        int "SD CMD GPIO"
        default 44

    config MCR_SD_PIN_CLK
        int "SD CLK GPIO"
        default 43

    config MCR_SD_PIN_D0
        int "SD D0 GPIO"
        default 39

    config MCR_SD_BUS_WIDTH_4
        bool "SD 4-bit bus"
        default y

    config MCR_SD_PIN_D1
        int "SD D1 GPIO"
        depends on MCR_SD_BUS_WIDTH_4
        default 40

    config MCR_SD_PIN_D2
        int "SD D2 GPIO"
        depends on MCR_SD_BUS_WIDTH_4
        default 41

    config MCR_SD_PIN_D3
        int "SD D3 GPIO"
        depends on MCR_SD_BUS_WIDTH_4
        default 42

    config MCR_SD_LDO_CHAN
        int "SD power LDO channel (-1 = external power)"
        default 4
        help
            On the ESP32-P4-Function-EV-Board the SD slot is powered from
            the on-chip LDO channel 4. Set -1 if the slot is powered
            externally.

endmenu
